<%- include('../partials/head', { title: title, extraCSS: ['/css/auth.css'] }) %>

<body>
<%- include('../partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2><%= t('auth.verifyTitle') %></h2>
      <p><%= t('auth.verifySubtitle') %></p>
    </div>

    <% if (typeof resent !== 'undefined' && resent) { %>
      <div class="auth-success"><i class="fas fa-check-circle"></i> <%= t('auth.codeResent') %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= t(error) %></div>
    <% } %>

    <p class="u-note-center">
      <%= t('auth.codeSentTo') %> <strong><%= email %></strong>
    </p>

    <form class="auth-form" method="POST" action="/verify-email">
      <div class="input-group">
        <i class="fas fa-shield-alt"></i>
        <input type="text" name="code" inputmode="numeric" pattern="[0-9]*" maxlength="6"
               placeholder="<%= t('auth.verifyCodePlaceholder') %>" required
               class="u-code-input">
      </div>
      <button type="submit" class="btn-primary btn-full"><%= t('auth.verifyButton') %></button>
    </form>

    <form method="POST" action="/resend-code" class="u-mt-center">
      <button type="submit" class="link-button"><%= t('auth.resendCode') %></button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
