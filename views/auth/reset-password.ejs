<%- include('../partials/head', { title: title, extraCSS: ['/css/auth.css'] }) %>

<body>
<%- include('../partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2><%= t('auth.resetTitle') %></h2>
      <p><%= t('auth.resetSubtitle') %></p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= t(error) %></div>
    <% } %>

    <form class="auth-form" method="POST" action="/reset-password/<%= token %>">
      <div class="input-group">
        <i class="fas fa-lock"></i>
        <div class="password-wrapper">
          <input type="password" id="newPassword" name="password" placeholder="<%= t('auth.newPassword') %>" required>
          <button type="button" class="password-toggle" data-target="newPassword" tabindex="-1"><i class="far fa-eye"></i></button>
        </div>
      </div>
      <div class="input-group">
        <i class="fas fa-lock"></i>
        <input type="password" name="confirmPassword" placeholder="<%= t('auth.confirmPassword') %>" required>
      </div>
      <button type="submit" class="btn-primary btn-full"><%= t('auth.resetButton') %></button>
      <p class="auth-switch"><a href="/login"><%= t('auth.backToLogin') %></a></p>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
<script src="/js/auth.js"></script>
</body>
</html>
