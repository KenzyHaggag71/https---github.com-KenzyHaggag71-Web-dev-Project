<%- include('../partials/head', { title: title, extraCSS: ['/css/auth.css'] }) %>

<body>
<%- include('../partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2><%= t('auth.forgotTitle') %></h2>
      <p><%= t('auth.forgotSubtitle') %></p>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="auth-success"><i class="fas fa-check-circle"></i> <%= t(success) %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= t(error) %></div>
    <% } %>
