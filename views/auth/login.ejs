<%- include('../partials/head', { title: title, extraCSS: ['/css/auth.css'] }) %>

<body>
<%- include('../partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2><%= t('auth.welcomeBack') %></h2>
      <p><%= t('auth.signinSubtitle') %></p>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="auth-success">
        <i class="fas fa-check-circle"></i>
        <%= t(success) %>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="auth-error">
        <i class="fas fa-exclamation-circle"></i>
        <%= t(error) %>
      </div>
    <% } %>

    <form class="auth-form" method="POST" action="/login" novalidate>
      <div class="input-group">
        <i class="fas fa-envelope"></i>
        <input
          type="text"
          name="email"
          placeholder="<%= t('auth.emailPlaceholder') %>"
          value="<%= formData.email || '' %>"
          required>
      </div>

      <div class="input-group">
        <i class="fas fa-lock"></i>
        <div class="password-wrapper">
          <input type="password" id="loginPassword" name="password" placeholder="<%= t('auth.passwordPlaceholder') %>" required>
          <button type="button" class="password-toggle" id="passwordToggle" tabindex="-1">
            <i class="far fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-primary btn-full"><%= t('auth.signIn') %></button>

      <p class="auth-switch u-mt-10">
        <a href="/forgot-password"><%= t('auth.forgotPassword') %></a>
      </p>

      <p class="auth-switch">
        <%= t('auth.noAccount') %>
        <a href="/signup"><%= t('auth.createAccount') %></a>
      </p>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>

<script src="/js/auth.js"></script>
</body>
</html>
