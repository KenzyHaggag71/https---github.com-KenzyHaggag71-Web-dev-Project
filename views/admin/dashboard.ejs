<%- include('../partials/head', { title: 'Admin Hub — InternHub', extraCSS: ['/css/admin.css'] }) %>

<body class="admin-page">
<%- include('../partials/navbar') %>

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <i class="fas fa-shield-alt"></i>
      <span><%= t('nav.adminHub') %></span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="nav-item active"><i class="fas fa-tachometer-alt"></i> <%= t('admin.dashboard') %></a>
      <a href="/admin/users" class="nav-item"><i class="fas fa-users"></i> <%= t('admin.manageUsers') %></a>
      <a href="/admin/approvals" class="nav-item"><i class="fas fa-check-circle"></i> <%= t('admin.approvals') %>
        <% if (pendingCount > 0) { %><span class="badge"><%= pendingCount %></span><% } %>
      </a>
      <a href="/admin/internships" class="nav-item"><i class="fas fa-briefcase"></i> <%= t('admin.internships') %></a>
      <a href="/logout" class="nav-item nav-logout"><i class="fas fa-sign-out-alt"></i> <%= t('nav.logout') %></a>
    </nav>
  </aside>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1><%= t('admin.dashboard') %></h1>
      <div class="admin-user-info">
        <i class="fas fa-user-shield"></i>
        <span><%= currentUser.name %></span>
      </div>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= t(flash.message) %></div>
    <% } %>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon purple"><i class="fas fa-users"></i></div>
        <div class="stat-info">
          <h3><%= stats.totalUsers %></h3>
          <p><%= t('admin.totalUsers') %></p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-building"></i></div>
        <div class="stat-info">
          <h3><%= stats.companies %></h3>
          <p><%= t('nav.companies') %></p>
          <% if (stats.pendingCompanies > 0) { %>
            <small class="pending-note"><%= t('admin.pendingNote', { count: stats.pendingCompanies }) %></small>
          <% } %>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-chalkboard-teacher"></i></div>
        <div class="stat-info">
          <h3><%= stats.mentors %></h3>
          <p><%= t('admin.mentors') %></p>
          <% if (stats.pendingMentors > 0) { %>
            <small class="pending-note"><%= t('admin.pendingNote', { count: stats.pendingMentors }) %></small>
          <% } %>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon orange"><i class="fas fa-user-graduate"></i></div>
        <div class="stat-info">
          <h3><%= stats.students %></h3>
          <p><%= t('admin.students') %></p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon pink"><i class="fas fa-briefcase"></i></div>
        <div class="stat-info">
          <h3><%= stats.internships %></h3>
          <p><%= t('admin.internships') %></p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon teal"><i class="fas fa-file-alt"></i></div>
        <div class="stat-info">
          <h3><%= stats.applications %></h3>
          <p><%= t('admin.applications') %></p>
        </div>
      </div>
    </div>

    <% if (typeof charts !== 'undefined' && charts) { %>
      <%
        var __c = {
          roleLabels: [t('admin.students'), t('admin.mentors'), t('nav.companies')],
          roleData:   [charts.usersByRole.students, charts.usersByRole.mentors, charts.usersByRole.companies],
          catLabels:  charts.categories.map(function(c){ return tEnum('category', c.key); }),
          catData:    charts.categories.map(function(c){ return c.count; }),
          statusLabels: charts.statuses.map(function(s){ return tEnum('status', s.key); }),
          statusData:   charts.statuses.map(function(s){ return s.count; }),
          rtl: (typeof dir !== 'undefined' && dir === 'rtl')
        };
      %>
      <div class="panel">
        <div class="panel-header"><h2><i class="fas fa-chart-pie"></i> <%= t('admin.analytics') %></h2></div>
        <div class="charts-grid" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;padding:18px;">
          <div><h3 style="text-align:center;font-size:.95rem;margin-bottom:8px;"><%= t('admin.chartUsers') %></h3><canvas id="chartUsers" height="200"></canvas></div>
          <div><h3 style="text-align:center;font-size:.95rem;margin-bottom:8px;"><%= t('admin.chartCategories') %></h3><canvas id="chartCats" height="200"></canvas></div>
          <div><h3 style="text-align:center;font-size:.95rem;margin-bottom:8px;"><%= t('admin.chartStatus') %></h3><canvas id="chartStatus" height="200"></canvas></div>
        </div>
      </div>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
      <script>
        (function () {
          var C = <%- JSON.stringify(__c) %>;
          if (typeof Chart === 'undefined') { return; }
          var palette = ['#3457DC','#16A34A','#D97706','#DC2626','#9333EA','#0891B2','#DB2777','#65A30D','#EA580C'];
          var gridColor = getComputedStyle(document.documentElement).getPropertyValue('--border') || '#E4E4E4';
          Chart.defaults.font.family = 'Plus Jakarta Sans, Cairo, sans-serif';
          new Chart(document.getElementById('chartUsers'), {
            type: 'bar',
            data: { labels: C.roleLabels, datasets: [{ data: C.roleData, backgroundColor: palette.slice(0,3), borderRadius: 6 }] },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: gridColor } }, x: { grid: { display: false } } } }
          });
          new Chart(document.getElementById('chartCats'), {
            type: 'doughnut',
            data: { labels: C.catLabels, datasets: [{ data: C.catData, backgroundColor: palette }] },
            options: { plugins: { legend: { position: 'bottom', rtl: C.rtl, labels: { boxWidth: 12, font: { size: 11 } } } } }
          });
          new Chart(document.getElementById('chartStatus'), {
            type: 'bar',
            data: { labels: C.statusLabels, datasets: [{ data: C.statusData, backgroundColor: palette.slice(0,4), borderRadius: 6 }] },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: gridColor } }, x: { grid: { display: false } } } }
          });
        })();
      </script>
    <% } %>

    <div class="admin-panels">
      <div class="panel">
        <div class="panel-header">
          <h2><i class="fas fa-building"></i> <%= t('admin.pendingCompanies') %></h2>
          <a href="/admin/approvals" class="panel-link"><%= t('admin.viewAll') %></a>
        </div>
        <% if (pendingCompanies.length === 0) { %>
          <p class="empty-msg"><%= t('No pending company approvals.') %></p>
        <% } else { %>
          <% pendingCompanies.slice(0,5).forEach(function(c) { %>
            <div class="pending-item">
              <div class="pending-info">
                <strong><%= c.companyName || c.name %></strong>
                <p><%= c.email %></p>
                <p><%= c.industry ? tIndustry(c.industry) : '' %></p>
              </div>
              <div class="pending-actions">
                <form action="/admin/approve/<%= c._id %>" method="POST" style="display:inline">
                  <button class="btn-approve"><%= t('admin.approve') %></button>
                </form>
                <form action="/admin/reject/<%= c._id %>" method="POST" style="display:inline">
                  <button class="btn-reject"><%= t('admin.reject') %></button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div class="panel">
        <div class="panel-header">
          <h2><i class="fas fa-chalkboard-teacher"></i> <%= t('admin.pendingMentors') %></h2>
          <a href="/admin/approvals" class="panel-link"><%= t('admin.viewAll') %></a>
        </div>
        <% if (pendingMentors.length === 0) { %>
          <p class="empty-msg"><%= t('No pending mentor applications.') %></p>
        <% } else { %>
          <% pendingMentors.slice(0,5).forEach(function(m) { %>
            <div class="pending-item">
              <div class="pending-info">
                <strong><%= m.profile && m.profile.fullName ? m.profile.fullName : m.name %></strong>
                <p><%= m.email %></p>
                <p><%= m.profile && m.profile.university ? m.profile.university : '' %></p>
              </div>
              <div class="pending-actions">
                <form action="/admin/approve/<%= m._id %>" method="POST" style="display:inline">
                  <button class="btn-approve"><%= t('admin.approve') %></button>
                </form>
                <form action="/admin/reject/<%= m._id %>" method="POST" style="display:inline">
                  <button class="btn-reject"><%= t('admin.reject') %></button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
</body>
</html>
