<%- include('../partials/head', { title: 'Manage Users - Admin', extraCSS: ['/css/admin.css'] }) %>

<body class="admin-page">
<%- include('../partials/navbar') %>



<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-header">
      <i class="fas fa-shield-alt"></i>
      <span><%= t('nav.adminHub') %></span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> <%= t('admin.dashboard') %></a>
      <a href="/admin/users" class="nav-item active"><i class="fas fa-users"></i> <%= t('admin.manageUsers') %></a>
      <a href="/admin/approvals" class="nav-item"><i class="fas fa-check-circle"></i> <%= t('admin.approvals') %></a>
      <a href="/admin/internships" class="nav-item"><i class="fas fa-briefcase"></i> <%= t('admin.internships') %></a>
      <a href="/logout" class="nav-item nav-logout"><i class="fas fa-sign-out-alt"></i> <%= t('nav.logout') %></a>
    </nav>
  </aside>

  <main class="admin-main">
    <div id="pageContent">
    <div class="admin-topbar">
      <h1><%= t('admin.manageUsers') %></h1>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= t(flash.message) %></div>
    <% } %>

    <div class="admin-users-panel">
      <div class="admin-users-header">
        <h2><%= t('admin.allUsers', { count: (typeof pagination !== 'undefined' ? pagination.totalItems : users.length) }) %></h2>
        <form method="GET" action="/admin/users" class="search-form">
          <input type="text" name="search" placeholder="<%= t('admin.searchUsers') %>" value="<%= search || '' %>" class="search-input">
          <button type="submit" class="btn-search"><i class="fas fa-search"></i></button>
        </form>
      </div>

      <div class="table-wrap">
        <div class="table-scroll"><table class="admin-table">
          <thead>
            <tr>
              <th>#</th>
              <th><%= t('common.name') %></th>
              <th><%= t('common.email') %></th>
              <th><%= t('common.role') %></th>
              <th><%= t('common.status') %></th>
              <th><%= t('common.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr><td colspan="6" class="text-center"><%= t('admin.noUsers') %></td></tr>
            <% } %>

            <% var rowOffset = (typeof pagination !== 'undefined') ? (pagination.page - 1) * pagination.limit : 0; %>
            <% users.forEach(function(user, i) { %>
              <tr>
                <td><%= rowOffset + i + 1 %></td>
                <td>
                  <div class="user-name-cell">
                    <span class="user-avatar"><i class="fas fa-user"></i></span>
                    <span><%= user.name %></span>
                  </div>
                </td>
                <td class="email-cell"><%= user.email %></td>
                <td><span class="role-badge role-<%= user.role %>"><%= tEnum("role", user.role) %></span></td>
                <td data-ajax-status>
                  <% if (user.status === 'active' || user.status === 'approved') { %>
                    <span class="status-badge status-active"><%= t('common.active') %></span>
                  <% } else if (user.status === 'blocked') { %>
                    <span class="status-badge status-blocked"><%= t('common.blocked') %></span>
                  <% } else if (user.status === 'pending') { %>
                    <span class="status-badge status-pending"><%= t('common.pending') %></span>
                  <% } else { %>
                    <span class="status-badge"><%= user.status %></span>
                  <% } %>
                </td>
                <td>
                  <% if (user.role === 'admin') { %>
                    <span class="admin-lock"><i class="fas fa-lock"></i> <%= t('admin.adminLabel') %></span>
                  <% } else { %>
                    <div class="action-group">
                      <form action="/admin/toggle-block/<%= user._id %>" method="POST" data-ajax="toggle" data-label-block="<%= t('admin.block') %>" data-label-unblock="<%= t('admin.unblock') %>">
                        <% if (user.status === 'blocked') { %>
                          <button class="btn-sm btn-unblock"><%= t('admin.unblock') %></button>
                        <% } else { %>
                          <button class="btn-sm btn-block"><%= t('admin.block') %></button>
                        <% } %>
                      </form>

                      <form action="/admin/delete-user/<%= user._id %>" method="POST" data-ajax="remove" data-ajax-confirm="<%= t('admin.deleteUserConfirm') %>">
                        <button class="btn-sm btn-delete"><%= t('common.delete') %></button>
                      </form>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table></div>
      </div>

      <%- include('../partials/pagination', { pagination: pagination, baseUrl: baseUrl, baseQuery: baseQuery }) %>
    </div>
  </div>
  </main>
</div>

<%- include('../partials/footer') %>
</body>
</html>
