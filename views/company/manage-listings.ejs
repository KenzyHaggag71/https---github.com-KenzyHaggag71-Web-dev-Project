<%- include('../partials/head', { title: 'My Listings — InternHub', extraCSS: ['/css/company.css'] }) %>

<body class="company-page">
<%- include('../partials/navbar') %>

<div class="company-layout">
  <aside class="company-sidebar">
    <div class="sidebar-header">
      <i class="fas fa-building"></i>
      <span><%= currentUser.companyName || currentUser.name %></span>
    </div>
    <nav class="sidebar-nav">
      <a href="/company/dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> <%= t('sidebar.dashboard') %></a>
      <a href="/company/post-internship" class="nav-item"><i class="fas fa-plus-circle"></i> <%= t('company.postInternship') %></a>
      <a href="/company/manage-listings" class="nav-item active"><i class="fas fa-list"></i> <%= t('company.myListings') %></a>
      <a href="/company/applications" class="nav-item"><i class="fas fa-file-alt"></i> <%= t('company.applications') %></a>
      <a href="/company/my-students" class="nav-item"><i class="fas fa-user-graduate"></i> <%= t('company.myStudents') %></a>
      <a href="/logout" class="nav-item nav-logout"><i class="fas fa-sign-out-alt"></i> <%= t('sidebar.logout') %></a>
    </nav>
  </aside>

  <main class="company-main">
    <div class="company-topbar">
      <h1><%= t('company.myListings') %></h1>
      <a href="/company/post-internship" class="btn-primary"><i class="fas fa-plus"></i> <%= t('company.postNew') %></a>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= t(flash.message) %></div>
    <% } %>

    <% if (listings.length === 0) { %>
      <div class="panel">
        <p class="empty-msg"><%= t('company.noListingsYet') %> <a href="/company/post-internship"><%= t('company.postOneNow') %></a></p>
      </div>
    <% } else { %>
      <div class="listings-grid">
        <% listings.forEach(function(l) { %>
          <div class="company-listing-card" data-ajax-item>
            <div class="listing-header">
              <div class="listing-title"><%= t(l.title) %></div>
              <span class="type-badge type-<%= l.type.toLowerCase() %>"><%= tEnum('type', l.type) %></span>
            </div>
            <div class="listing-meta">
              <span><i class="fas fa-tag"></i> <%= tEnum('category', l.category) %></span>
              <span><i class="fas fa-map-marker-alt"></i> <%= tEnum('workMode', l.workMode) %></span>
              <span><i class="fas fa-coins"></i> <%= l.stipend ? tStipend(l.stipend) : tEnum('type', l.type) %></span>
            </div>
            <p class="listing-desc"><%= t(l.description) %></p>
            <% if (l.skills && l.skills.length > 0) { %>
              <div class="skill-tags">
                <% l.skills.forEach(function(sk) { %><span class="skill-tag"><%= sk %></span><% }) %>
              </div>
            <% } %>
            <div class="listing-actions">
              <a href="/company/edit-internship/<%= l._id %>" class="btn-sm btn-edit"><i class="fas fa-edit"></i> <%= t('common.edit') %></a>
              <form action="/company/delete-internship/<%= l._id %>" method="POST" class="u-inline" data-ajax="remove" data-ajax-confirm="<%= t('company.deleteListingConfirm') %>">
                <button class="btn-sm btn-delete"><i class="fas fa-trash"></i> <%= t('common.delete') %></button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>

<%- include('../partials/footer') %>
</body>
</html>
