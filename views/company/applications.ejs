<%- include('../partials/head', { title: 'Applications — InternHub', extraCSS: ['/css/company.css'] }) %>

<body class="company-page">
<%- include('../partials/navbar') %>

<div class="company-layout">
  <aside class="company-sidebar">
    <div class="sidebar-header">
      <i class="fas fa-building"></i>
      <span><%= currentUser.companyName || currentUser.name %></span>
    </div>
    <nav class="sidebar-nav">
      <a href="/company/dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> <%= t('sidebar.dashboard') %></a>
      <a href="/company/post-internship" class="nav-item"><i class="fas fa-plus-circle"></i> <%= t('company.postInternship') %></a>
      <a href="/company/manage-listings" class="nav-item"><i class="fas fa-list"></i> <%= t('company.myListings') %></a>
      <a href="/company/applications" class="nav-item active"><i class="fas fa-file-alt"></i> <%= t('company.applications') %></a>
      <a href="/company/my-students" class="nav-item"><i class="fas fa-user-graduate"></i> <%= t('company.myStudents') %></a>
      <a href="/logout" class="nav-item nav-logout"><i class="fas fa-sign-out-alt"></i> <%= t('sidebar.logout') %></a>
    </nav>
  </aside>

  <main class="company-main">
    <div id="pageContent">
    <div class="company-topbar">
      <h1><%= t('company.applications') %> (<%= applications.length %>)</h1>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= t(flash.message) %></div>
    <% } %>

    <% if (applications.length === 0) { %>
      <div class="panel">
        <p class="empty-msg"><%= t('company.noApplicationsReceived') %></p>
      </div>
    <% } else { %>
      <% applications.forEach(function(app) { %>
        <div class="application-card">
          <div class="app-header">
            <div class="app-student">
              <div class="avatar-circle"><%= app.studentName.charAt(0).toUpperCase() %></div>
              <div>
                <strong><%= app.studentName %></strong>
                <p><%= app.studentEmail %></p>
                <p><%= app.studentUniversity %> · <%= app.studentMajor %></p>
              </div>
            </div>
            <div class="app-meta">
              <span class="status-badge status-<%= app.status %>"><%= tEnum('status', app.status) %></span>
              <p class="app-date"><%= new Date(app.createdAt).toLocaleDateString() %></p>
            </div>
          </div>
          <div class="app-internship">
            <i class="fas fa-briefcase"></i>
            <strong><%= app.internshipId ? t(app.internshipId.title) : 'N/A' %></strong>
          </div>
          <% if (app.cvFilePath) { %>
            <div class="app-cv">
              <a href="/company/cv/<%= app._id %>" target="_blank" class="btn-sm btn-outline"><i class="fas fa-file-pdf"></i> <%= t('company.viewCv') %></a>
            </div>
          <% } %>
          <% if (app.status === 'pending') { %>
            <div class="app-actions" data-ajax-actions>
              <form action="/company/accept-application/<%= app._id %>" method="POST" class="u-inline" data-ajax="status" data-ajax-done="<%= t('status.accepted') %>">
                <button class="btn-approve"><i class="fas fa-check"></i> <%= t('company.accept') %></button>
              </form>
              <form action="/company/reject-application/<%= app._id %>" method="POST" class="u-inline" data-ajax="status" data-ajax-done="<%= t('status.rejected') %>" data-ajax-confirm="Reject this application?">
                <button class="btn-reject"><i class="fas fa-times"></i> <%= t('admin.reject') %></button>
              </form>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } %>

    <%- include('../partials/pagination', { pagination: pagination, baseUrl: baseUrl, baseQuery: baseQuery }) %>
  </div>
  </main>
</div>

<%- include('../partials/footer') %>
</body>
</html>
