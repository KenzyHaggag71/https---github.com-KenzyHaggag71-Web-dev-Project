<%- include('../partials/head', { title: 'Acceptance Letter — InternHub', extraCSS: ['/css/acceptance-letter.css'] }) %>

<body class="letter-page">
<%- include('../partials/navbar') %>

<div class="letter-wrap">
  <div class="letter-actions">
    <a href="/student/my-internships" class="btn-sm btn-outline"><i class="fas fa-arrow-left"></i> <%= t('student.myApplications') %></a>
    <button type="button" class="btn-sm btn-primary" data-print><i class="fas fa-print"></i> <%= t('letter.print') %></button>
  </div>

  <div class="letter-sheet">
    <div class="letter-accent"></div>
    <div class="letter-inner">
      <div class="letter-head">
        <div class="letter-brand"><i class="fas fa-briefcase"></i> InternHub</div>
        <div class="letter-ref"><%= t('letter.date') %>: <%= new Date().toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US') %></div>
      </div>

      <h1 class="letter-h1"><%= t('letter.title') %></h1>

      <p><%= t('letter.dear') %> <strong><%= studentName %></strong>،</p>
      <p><%= t('letter.body1') %></p>

      <div class="letter-details">
        <div class="letter-row"><span class="k"><%= t('letter.position') %></span><span class="v"><%= t(application.internshipId.title) %></span></div>
        <div class="letter-row"><span class="k"><%= t('letter.company') %></span><span class="v"><%= application.internshipId.company %></span></div>
      </div>

      <p><%= t('letter.body2') %></p>

      <div class="letter-sign">
        <p><%= t('letter.regards') %></p>
        <div class="sig">InternHub</div>
        <p class="sig-title"><%= t('letter.team') %></p>
      </div>

      <div class="letter-foot">InternHub · Connecting students with dream internships</div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
